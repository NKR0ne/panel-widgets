{
  "$schema": "http://adaptivecards.io/schemas/adaptive-card.json",
  "type": "AdaptiveCard",
  "version": "1.5",
  "body": [
    {
      "type": "TextBlock",
      "text": "${time}",
      "size": "ExtraLarge",
      "weight": "Bolder",
      "horizontalAlignment": "Center",
      "spacing": "None"
    },
    {
      "type": "TextBlock",
      "text": "${date}",
      "size": "Small",
      "horizontalAlignment": "Center",
      "isSubtle": true,
      "spacing": "None"
    }
  ]
}
